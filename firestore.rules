rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // A user may create their own profile doc, but never with a
      // subscription field — that field is only ever written server-side
      // by the Stripe webhook (fire-api) via the Firebase Admin SDK, which
      // bypasses these rules entirely.
      allow create: if request.auth != null && request.auth.uid == userId
                    && !('subscription' in request.resource.data);

      // A user may update their own profile (state/portfolio/budget/
      // scenarios/userProfile), but the subscription field must come out
      // unchanged. merge:true writes from the client preserve the existing
      // subscription value automatically as long as they don't include it.
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.get('subscription', null)
                       == resource.data.get('subscription', null);
    }
  }
}
